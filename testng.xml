<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Nespresso QA Architect Suite" parallel="false">
    <listeners>
        <listener class-name="com.nespresso.qa.listeners.ExtentListener"/>
    </listeners>
    <test name="UI Tests">
        <classes>
            <class name="com.nespresso.qa.tests.ui.AddRemoveElementsTest"/>
            <class name="com.nespresso.qa.tests.ui.ChallengingDomTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="com.nespresso.qa.tests.api.UsersCrudTest"/>
        </classes>
    </test>
</suite>